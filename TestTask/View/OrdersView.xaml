<UserControl x:Class="TestTask.View.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ToolBar Grid.Row="0" Margin="0,0,0,4">
            <Button Content="Добавить"      Command="{Binding AddCommand}"    Padding="8,2"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}"   Padding="8,2"/>
            <Button Content="Удалить"       Command="{Binding DeleteCommand}" Padding="8,2"/>
        </ToolBar>
        <DataGrid Grid.Row="1" AutoGenerateColumns="False"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding Selected}"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding Id}"                            Width="50"/>
                <DataGridTextColumn Header="Дата"        Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Сумма"       Binding="{Binding Amount, StringFormat=N2}"       Width="120"/>
                <DataGridTextColumn Header="Сотрудник"   Binding="{Binding Employee.FullName}"             Width="*"/>
                <DataGridTextColumn Header="Контрагент"  Binding="{Binding Contractor.Name}"               Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
